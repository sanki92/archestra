# code execution runtime — the Dagger Engine that backs the archestra__run_python tool.
#
# deployed through the same companion chart used in production, but with network
# policies disabled because the backend runs on the developer machine and reaches
# dagger through a local kubectl port-forward. The root Tiltfile loads this file
# only when ARCHESTRA_CODE_RUNTIME_ENABLED=true, so the
# privileged engine is not deployed unless the feature is on.

# the chart renders namespaced resources; create its namespace alongside them.
k8s_yaml(blob('''apiVersion: v1
kind: Namespace
metadata:
  name: dagger
'''))

# render the chart client-side and let Tilt own the apply — same pattern as the
# mcp-rbac resources in Tiltfile.dev.
k8s_yaml(local(
  'helm template dagger-runtime ../helm/dagger-runtime --namespace dagger ' +
  '--set networkPolicy.create=false ' +
  '--set dagger.engine.readinessProbeSettings.periodSeconds=60 ' +
  '--set dagger.engine.livenessProbeSettings.periodSeconds=120',
  quiet=True,
))

# the backend reaches this service through the local port-forward below.
k8s_resource(
  'dagger-runtime-engine',
  new_name='dagger-engine',
  labels=['code-runtime'],
  objects=['dagger:namespace'],
)

local_resource(
  'dagger-runtime-port-forward',
  serve_cmd='while true; do kubectl -n dagger wait --for=condition=Ready pod -l name=dagger-runtime-engine --timeout=60s >/dev/null 2>&1 && kubectl -n dagger port-forward svc/dagger-runtime 1234:1234; sleep 2; done',
  labels=['code-runtime'],
  resource_deps=['dagger-engine'],
)
