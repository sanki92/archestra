{
  "name": "windmill-mcp-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "MCP server exposing Windmill flows as interactive MCP Apps in Archestra",
  "main": "dist/main.js",
  "scripts": {
    "build": "npm run build:ui && npm run build:server",
    "build:ui": "cross-env INPUT=src/app/flow-editor.html vite build",
    "build:server": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "test": "vitest",
    "type-check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.app.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.1.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/node": "^25.5.0",
    "cross-env": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.3.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
