{
  "name": "windmill-mcp-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "MCP server exposing Windmill flows as interactive MCP Apps in Archestra",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
